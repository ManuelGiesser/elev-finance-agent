cat > setup_starter.sh <<'EOF'
#!/bin/bash
set -e

mkdir -p db/init services/api/app services/worker/app services/mcp/app services/dashboard/app data

cat > docker-compose.yml <<'YAML'
services:
  api:
    build: ./services/api
    container_name: elev_api
    env_file: .env
    ports:
      - "${API_PORT:-8000}:8000"
    depends_on:
      - postgres
      - redis
    restart: unless-stopped

  worker:
    build: ./services/worker
    container_name: elev_worker
    env_file: .env
    depends_on:
      - postgres
      - redis
    restart: unless-stopped

  mcp:
    build: ./services/mcp
    container_name: elev_mcp
    env_file: .env
    ports:
      - "${MCP_PORT:-8010}:8010"
    restart: unless-stopped

  dashboard:
    build: ./services/dashboard
    container_name: elev_dashboard
    env_file: .env
    environment:
      API_URL: http://api:8000
    ports:
      - "${DASHBOARD_PORT:-8501}:8501"
    depends_on:
      - api
    restart: unless-stopped

  postgres:
    image: postgres:16
    container_name: elev_postgres
    env_file: .env
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-elev_finance}
      POSTGRES_USER: ${POSTGRES_USER:-elev}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-change_me}
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./db/init:/docker-entrypoint-initdb.d
    restart: unless-stopped

  redis:
    image: redis:7-alpine
    container_name: elev_redis
    restart: unless-stopped

volumes:
  postgres_data:
YAML

