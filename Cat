import os, requests, streamlit as st
API_URL = os.getenv("API_URL", "http://api:8000")
st.set_page_config(page_title="ELEV Finance Agent", layout="wide")
st.title("ELEV Finance Agent")
summary = requests.get(f"{API_URL}/dashboard/summary", timeout=5).json()
cols = st.columns(4)
cols[0].metric("Offene Buchungen", summary.get("transactions_open", 0))
cols[1].metric("Neue Belege", summary.get("receipts_new", 0))
cols[2].metric("Offene Vorgänge", summary.get("cases_open", 0))
cols[3].metric("Überfällig", summary.get("cases_overdue", 0))
st.json(summary)
EOF2

